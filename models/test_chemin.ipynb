    "import os\n",
    "\n",
    "def dossier_existe(chemin):\n",
    "    return os.path.isdir(chemin)\n",
    "\n",
    "chemin = \"../../../data/challenge2026MIASHS/PA\"\n",
    "\n",
    "if dossier_existe(chemin):\n",
    "    print(\"✅ Dossier trouvé\")\n",
    "else:\n",
    "    print(\"❌ Dossier introuvable\")"
   ]
